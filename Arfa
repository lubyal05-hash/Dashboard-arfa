  const colors = ['bg-orange-400','bg-pink-500','bg-blue-500','bg-green-500','bg-purple-500','bg-yellow-400','bg-red-400','bg-indigo-500'];

  document.getElementById('tokoList').innerHTML = tokos.length
    ? tokos.map((t, i) => {
