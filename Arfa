<script>
// ═══════════════════════════════════════════════════════════════════════
// BIAYA OPERASIONAL
// ═══════════════════════════════════════════════════════════════════════
// FIX: Use FormData consistently (form uses name attributes)
function submitBiaya(e) {
  e.preventDefault();
  const fd = new FormData(e.target);
  const tanggal = fd.get('tanggal');
  const ket = fd.get('ket');
  const jumlah = +fd.get('jumlah');

  if (!tanggal) return toast('Tanggal wajib diisi', 'error');
  if (!ket || !ket.trim()) return toast('Keterangan wajib diisi', 'error');
  if (!jumlah || jumlah <= 0) return toast('Jumlah harus lebih dari 0', 'error');

  const biaya = DB.get('biaya');
  biaya.unshift({
    id: uid(),
    tanggal,
    kategori: fd.get('kategori'),
    ket: ket.trim(),
    jumlah
  });
  DB.set('biaya', biaya);
  DB.save('biaya', biaya[0]);
  toggleBiayaForm(false);
  renderBiaya();
  renderDashboard();
  toast('✅ Biaya berhasil disimpan!');
}

function renderBiaya() {
  const biaya = DB.get('biaya');
  const total = biaya.reduce((s, b) => s + b.jumlah, 0);
  const top = biaya.slice().sort((a, b) => b.jumlah - a.jumlah)[0];
  document.getElementById('biaya-total').textContent = fmt(total);
  document.getElementById('biaya-top').textContent = top ? `${top.ket} (${fmt(top.jumlah)})` : '-';

  const cats = {
    Iklan: 'bg-red-100 text-red-700', Komisi: 'bg-orange-100 text-orange-700',
    Platform: 'bg-yellow-100 text-yellow-700', Gaji: 'bg-blue-100 text-blue-700',
    Sewa: 'bg-purple-100 text-purple-700', Utilitas: 'bg-green-100 text-green-700',
    Lainnya: 'bg-slate-100 text-slate-700'
  };

  const tbody = document.getElementById('biayaTbody');
  if (biaya.length === 0) {
    tbody.innerHTML = `<tr><td colspan="5"><div class="empty-state"><div class="icon">💸</div><p>Belum ada data biaya operasional.</p><p class="hint">Klik <strong>+ Tambah Biaya</strong> untuk mencatat pengeluaran.</p></div></td></tr>`;
  } else {
    tbody.innerHTML = biaya.map(b => `
      <tr class="border-t hover:bg-slate-50">
        <td class="px-5 py-3 text-slate-500">${b.tanggal}</td>
        <td class="px-5 py-3"><span class="text-xs px-2 py-0.5 rounded-full font-semibold ${cats[b.kategori] || 'bg-slate-100 text-slate-700'}">${b.kategori}</span></td>
        <td class="px-5 py-3">${b.ket}</td>
