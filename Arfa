}
</script>

<script>
// ═══════════════════════════════════════════════════════════════════════
// INVENTORY
// ═══════════════════════════════════════════════════════════════════════
// FIX: submitInv reads from element IDs (consistent with form using id attributes)
function submitInv(e) {
  e.preventDefault();
  const inv = DB.get('inventory');
  const existId = document.getElementById('fInvId').value;
  const nama = document.getElementById('fInvNama').value.trim();
  if (!nama) return toast('Nama produk wajib diisi', 'error');

  const item = {
    id: existId || uid(),
    nama,
    sku: document.getElementById('fInvSku').value.trim(),
    kategori: document.getElementById('fInvKat').value.trim(),
    harga_beli: +document.getElementById('fInvHB').value || 0,
    harga_jual: +document.getElementById('fInvHJ').value || 0,
    stok: +document.getElementById('fInvStok').value || 0,
    stok_min: +document.getElementById('fInvStokMin').value || 5
  };

  if (existId) {
    const idx = inv.findIndex(p => p.id === existId);
    if (idx >= 0) inv[idx] = item;
  } else {
    inv.push(item);
  }
  DB.set('inventory', inv);
  DB.save('inventory', item);
  toggleInvForm(false);
  renderInventory();
  updateProdukSuggest();
  toast(existId ? '✅ Produk berhasil diperbarui!' : '✅ Produk berhasil ditambahkan!');
  updateNavBadges();
}

function renderInventory() {
  const inv = DB.get('inventory');
  const q = (document.getElementById('srchInv')?.value || '').toLowerCase();
  const filtered = inv.filter(p => !q || p.nama.toLowerCase().includes(q) || (p.sku || '').toLowerCase().includes(q));

  document.getElementById('inv-total').textContent = inv.length;
  document.getElementById('inv-stok').textContent = inv.reduce((s, p) => s + p.stok, 0).toLocaleString('id-ID');
  document.getElementById('inv-nilai').textContent = fmt(inv.reduce((s, p) => s + (p.stok * p.harga_beli), 0));
  document.getElementById('inv-low').textContent = inv.filter(p => p.stok <= p.stok_min).length;

  const tbody = document.getElementById('invTbody');
  if (filtered.length === 0) {
    tbody.innerHTML = inv.length === 0
      ? `<tr><td colspan="8"><div class="empty-state"><div class="icon">📦</div><p>Belum ada produk di inventory.</p><p class="hint">Klik <strong>+ Tambah Produk</strong> untuk mulai mengelola stok.</p></div></td></tr>`
      : `<tr><td colspan="8" class="text-center py-10 text-slate-400">Tidak ada produk yang cocok.</td></tr>`;
  } else {
    tbody.innerHTML = filtered.map(p => `
      <tr class="border-t hover:bg-slate-50 ${p.stok <= p.stok_min ? 'bg-red-50' : ''}">
        <td class="px-4 py-3 font-medium">${p.nama}${p.stok <= p.stok_min ? ' <span class="text-xs text-red-500 font-semibold">⚠ Menipis</span>' : ''}</td>
        <td class="px-4 py-3 text-slate-500">${p.sku || '-'}</td>
        <td class="px-4 py-3 text-slate-500">${p.kategori || '-'}</td>
        <td class="px-4 py-3 text-right">${fmt(p.harga_beli)}</td>
        <td class="px-4 py-3 text-right">${fmt(p.harga_jual)}</td>
        <td class="px-4 py-3 text-right font-bold ${p.stok <= p.stok_min ? 'text-red-500' : ''}">${p.stok}</td>
        <td class="px-4 py-3 text-right">${fmt(p.stok * p.harga_beli)}</td>
