  document.getElementById('cf-siapkirim-count').textContent = siapKirim.length + ' order';
  document.getElementById('cf-omset').textContent          = fmt(paidOmset);

  const cfMasuk  = paidOmset + cf.filter(c => c.tipe === 'masuk').reduce((s, c) => s + c.jumlah, 0);
  const cfKeluar = biaya.reduce((s, b) => s + b.jumlah, 0) + cf.filter(c => c.tipe === 'keluar').reduce((s, c) => s + c.jumlah, 0);
  document.getElementById('cf-masuk').textContent  = fmt(cfMasuk);
  document.getElementById('cf-keluar').textContent = fmt(cfKeluar);
  document.getElementById('cf-net').textContent    = fmt(cfMasuk - cfKeluar);

  const renderList = (items, elId) => {
