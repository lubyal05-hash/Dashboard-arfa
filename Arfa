            <button onclick="delCF('${c.id}')" class="text-red-400 hover:text-red-600" title="Hapus transaksi">🗑</button>
          </td>
        </tr>`).join('')
    : `<tr><td colspan="5"><div class="empty-state"><div class="icon">💰</div><p>Belum ada transaksi manual.</p><p class="hint">Klik <strong>+ Tambah Transaksi</strong> untuk mencatat pemasukan/pengeluaran lain.</p></div></td></tr>`;
