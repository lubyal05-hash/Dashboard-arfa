          <button onclick="delInv('${p.id}')" class="text-red-400 hover:text-red-600" title="Hapus produk">🗑</button>
        </td>
      </tr>`).join('');
  }
}

function editInv(id) {
  const p = DB.get('inventory').find(x => x.id === id);
  if (!p) return;
  document.getElementById('fInvId').value = p.id;
  document.getElementById('fInvNama').value = p.nama;
  document.getElementById('fInvSku').value = p.sku || '';
  document.getElementById('fInvKat').value = p.kategori || '';
  document.getElementById('fInvHB').value = p.harga_beli;
  document.getElementById('fInvHJ').value = p.harga_jual;
  document.getElementById('fInvStok').value = p.stok;
  document.getElementById('fInvStokMin').value = p.stok_min;
  document.getElementById('invFormTitle').textContent = 'Edit Produk';
  const box = document.getElementById('invFormBox');
  box.style.display = 'block';
  box.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function delInv(id) {
  if (!confirm('Hapus produk ini dari inventory?')) return;
  DB.set('inventory', DB.get('inventory').filter(p => p.id !== id));
  DB.remove('inventory', id);
  renderInventory();
  updateProdukSuggest();
  updateNavBadges();
  toast('Produk berhasil dihapus.');
}

async function syncInventoryToSheet() {
  const s = DB.getObj('settings');
  if (!s.gsUrl) { toast('URL Google Sheets belum diisi di Settings', 'error'); return; }
  const inv = DB.get('inventory');
  try {
    await fetch(s.gsUrl, { method: 'POST', body: JSON.stringify({ action: 'syncInventory', items: inv }) });
    toast('Inventory berhasil disync ke Google Sheets!');
  } catch (err) { toast('Gagal sync: ' + err.message, 'error'); }
}

async function syncRingkasanToSheet() {
  const s = DB.getObj('settings');
  if (!s.gsUrl) { toast('URL Google Sheets belum diisi di Settings', 'error'); return; }
  const orders = DB.get('orders').filter(o => o.status === 'Paid');
  const inv = DB.get('inventory');
  const platforms = [...new Set(orders.map(o => o.toko || 'Offline'))];
  const rows = platforms.map(p => {
    const po = orders.filter(o => (o.toko || 'Offline') === p);
    const omset    = po.reduce((s, o) => s + (o.omset || 0), 0);
    const potongan = po.reduce((s, o) => s + (o.fee_mp||0) + (o.biaya_program||0) + (o.voucher||0) + (o.gratis_ongkir||0) + (o.promo_xtra||0), 0);
    const gross    = omset - potongan;
    const hpp      = po.reduce((s, o) => { const prod = inv.find(i => i.nama === o.product); return s + (prod ? prod.harga_beli * o.qty : 0); }, 0);
    return { platform: p, omset, potongan, gross, hpp, grossProfit: gross - hpp };
  });
  const total = rows.reduce((t, r) => ({ omset: t.omset+r.omset, potongan: t.potongan+r.potongan, gross: t.gross+r.gross, hpp: t.hpp+r.hpp, grossProfit: t.grossProfit+r.grossProfit }), { omset:0, potongan:0, gross:0, hpp:0, grossProfit:0 });
  try {
    await fetch(s.gsUrl, { method: 'POST', body: JSON.stringify({ action: 'syncRingkasan', rows, total }) });
    toast('Ringkasan berhasil disync ke Google Sheets!');
  } catch (err) { toast('Gagal sync: ' + err.message, 'error'); }
}
</script>

<script>
// ═══════════════════════════════════════════════════════════════════════
// TOKO / CHANNEL
// ═══════════════════════════════════════════════════════════════════════
// FIX: submitToko reads from element IDs (consistent with form using id attributes, no name attrs)
function submitToko(e) {
  e.preventDefault();
  const tokos = DB.get('tokos');
  const existId = document.getElementById('fTokoId').value;
  const nama = document.getElementById('fTokoNama').value.trim();
