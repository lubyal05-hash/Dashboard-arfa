<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>BizDashboard - Arfa Motor</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
<style>
*{box-sizing:border-box}
body{margin:0;font-family:Inter,sans-serif;background:#f1f5f9}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:3px}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;font-size:13px;cursor:pointer;color:#94a3b8;transition:all .15s;margin:2px 8px;text-decoration:none}
.nav-item:hover{background:#1e293b;color:#fff}
.nav-item.active{background:#2563eb;color:#fff;font-weight:600}
.nav-badge{margin-left:auto;background:rgba(255,255,255,.2);color:#fff;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px;min-width:18px;text-align:center}
.nav-item:not(.active) .nav-badge{background:#334155;color:#94a3b8}
.page{display:none}
.page.active{display:block}
.inp{width:100%;border:1px solid #e2e8f0;border-radius:8px;padding:10px 12px;font-size:14px;color:#1e293b;outline:none;transition:all .15s;background:#fff}
.inp:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.15)}
.btn{background:#2563eb;color:#fff;border:none;border-radius:8px;padding:9px 16px;font-size:13px;font-weight:600;cursor:pointer;transition:background .15s}
.btn:hover{background:#1d4ed8}
.btn:disabled{background:#93c5fd;cursor:not-allowed}
.btn-g{background:#22c55e}.btn-g:hover{background:#16a34a}
.btn-r{background:#ef4444}.btn-r:hover{background:#dc2626}
.btn-gray{background:#64748b}.btn-gray:hover{background:#475569}
.btn-sm{padding:6px 12px;font-size:12px}
.card{background:#fff;border-radius:12px;padding:16px;border:1px solid #f1f5f9;box-shadow:0 1px 3px rgba(0,0,0,.06)}
/* Modal - only for mOrder */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:100;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal{background:#fff;border-radius:16px;padding:24px;width:100%;max-width:620px;max-height:92vh;overflow-y:auto}
.lbl{display:block;font-size:11px;font-weight:600;color:#64748b;text-transform:uppercase;margin-bottom:4px}
.lbl-req::after{content:" *";color:#ef4444}
/* Inline form box */
.inline-form-box{display:none;background:#f8fafc;border:2px solid #3b82f6;border-radius:12px;padding:20px;margin-bottom:16px;animation:slideDown .2s ease}
@keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
/* Toast notification */
.toast{position:fixed;bottom:24px;right:24px;z-index:9999;padding:12px 20px;border-radius:10px;font-size:14px;font-weight:600;box-shadow:0 4px 12px rgba(0,0,0,.15);animation:slideUp .3s ease;max-width:320px}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.toast-success{background:#22c55e;color:#fff}
.toast-error{background:#ef4444;color:#fff}
/* Loading spinner */
.spinner{display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
/* Empty state */
.empty-state{text-align:center;padding:48px 20px;color:#94a3b8}
.empty-state .icon{font-size:48px;margin-bottom:12px}
.empty-state p{font-size:14px;margin:4px 0}
.empty-state .hint{font-size:12px;color:#cbd5e1;margin-top:8px}
/* Status badge */
.badge{display:inline-flex;align-items:center;font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px}
/* Hover row */
tr.trow:hover td{background:#f8fafc}
/* Quick start card */
.quick-start{background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;border-radius:16px;padding:24px;margin-bottom:16px}
.quick-start h2{font-size:18px;font-weight:700;margin:0 0 8px}
.quick-start p{font-size:13px;opacity:.85;margin:0 0 12px}
.quick-start ol{margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:8px}
.quick-start li{display:flex;align-items:center;gap:10px;font-size:13px;background:rgba(255,255,255,.15);border-radius:8px;padding:8px 12px}
.quick-start li .step{background:rgba(255,255,255,.3);border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
</style>
</head>
<body class="flex h-screen overflow-hidden">

<!-- SIDEBAR -->
<aside class="w-56 min-w-56 bg-slate-900 text-white flex flex-col h-screen">
  <div class="flex items-center gap-2 px-4 py-4 border-b border-slate-700">
    <div class="w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center font-bold text-sm">B</div>
    <div>
      <p class="text-sm font-bold" id="bizName">BizDashboard</p>
      <p class="text-xs text-slate-400" id="bizSub">Arfa Motor</p>
    </div>
  </div>
  <nav class="flex-1 py-3 overflow-y-auto">
    <a class="nav-item active" onclick="go(event,'dashboard')" href="#">📊 Dashboard</a>
    <a class="nav-item" onclick="go(event,'orders')" href="#">🛒 Orders<span class="nav-badge" id="nb-orders">0</span></a>
    <a class="nav-item" onclick="go(event,'cashflow')" href="#">💰 Cashflow</a>
    <a class="nav-item" onclick="go(event,'inventory')" href="#">📦 Inventory<span class="nav-badge" id="nb-inv">0</span></a>
    <a class="nav-item" onclick="go(event,'toko')" href="#">🏪 Toko / Channel<span class="nav-badge" id="nb-toko">0</span></a>
    <a class="nav-item" onclick="go(event,'biaya')" href="#">💸 Biaya Operasional</a>
    <a class="nav-item" onclick="go(event,'ai')" href="#">🤖 AI Insight</a>
    <a class="nav-item" onclick="go(event,'laporan')" href="#">📄 Laporan</a>
    <a class="nav-item" onclick="go(event,'settings')" href="#">⚙️ Settings</a>
  </nav>
  <div class="px-4 py-4 border-t border-slate-700">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-xs font-bold" id="ownerAvatar">A</div>
      <div>
        <p class="text-sm font-medium" id="ownerName">Admin</p>
        <p class="text-xs text-slate-400">Owner</p>
      </div>
    </div>
    <p class="text-xs text-slate-500 mt-2" id="sDate"></p>
    <p class="text-xs text-slate-500" id="sTime"></p>
  </div>
</aside>

<!-- MAIN -->
<div class="flex-1 flex flex-col overflow-hidden">
  <header class="bg-white border-b px-6 py-3 flex items-center justify-between">
    <h1 class="text-xl font-bold text-slate-800" id="pageTitle">Dashboard</h1>
    <span class="text-xs text-slate-400 bg-slate-100 px-3 py-1 rounded-full" id="hDate"></span>
  </header>
  <main class="flex-1 overflow-y-auto p-5">

<!-- ═══════════════════════════════════════════════════════ DASHBOARD ═══ -->
<div id="dashboard" class="page active space-y-4">
  <!-- Quick Start (shown when no orders) -->
  <div id="quickStart" class="quick-start" style="display:none">
    <h2>🚀 Selamat Datang di BizDashboard!</h2>
    <p>Belum ada data. Mulai dengan langkah berikut:</p>
    <ol>
      <li><span class="step">1</span> Tambah Toko/Channel di menu <strong>Toko / Channel</strong></li>
      <li><span class="step">2</span> Tambah produk di menu <strong>Inventory</strong></li>
      <li><span class="step">3</span> Input order pertama di menu <strong>Orders</strong></li>
    </ol>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
    <div class="card"><div class="flex items-start justify-between"><div><p class="text-xs text-slate-400 uppercase font-semibold">Total Omset</p><p class="text-2xl font-bold text-slate-800 mt-1" id="d-omset">Rp 0</p><p class="text-xs text-slate-400 mt-1">Semua order aktif</p></div><div class="w-9 h-9 bg-blue-100 rounded-lg flex items-center justify-center">🛒</div></div></div>
    <div class="card"><div class="flex items-start justify-between"><div><p class="text-xs text-slate-400 uppercase font-semibold">Est. Profit 20%</p><p class="text-2xl font-bold text-green-600 mt-1" id="d-profit">Rp 0</p><p class="text-xs text-slate-400 mt-1">Estimasi 20%</p></div><div class="w-9 h-9 bg-green-100 rounded-lg flex items-center justify-center">📈</div></div></div>
    <div class="card"><div class="flex items-start justify-between"><div><p class="text-xs text-slate-400 uppercase font-semibold">Total Pengeluaran</p><p class="text-2xl font-bold text-red-500 mt-1" id="d-pengeluaran">Rp 0</p><p class="text-xs text-slate-400 mt-1">Biaya operasional</p></div><div class="w-9 h-9 bg-red-100 rounded-lg flex items-center justify-center">💸</div></div></div>
    <div class="card"><div class="flex items-start justify-between"><div><p class="text-xs text-slate-400 uppercase font-semibold">Saldo Akhir</p><p class="text-2xl font-bold text-slate-800 mt-1" id="d-saldo">Rp 0</p><p class="text-xs text-slate-400 mt-1">Omset - Pengeluaran</p></div><div class="w-9 h-9 bg-purple-100 rounded-lg flex items-center justify-center">💳</div></div></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="card lg:col-span-2">
      <p class="text-xs font-bold text-slate-500 uppercase mb-3">Omset 14 Hari Terakhir</p>
      <canvas id="dashChart" height="130"></canvas>
    </div>
    <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-4 border border-blue-100">
      <div class="flex items-center justify-between mb-3">
        <p class="text-xs font-bold text-blue-600 uppercase">🤖 AI Insight</p>
        <span class="text-xs text-slate-400" id="ai-update">-</span>
      </div>
      <p class="text-xs text-slate-500 mb-1">Produk terlaris:</p>
      <p class="text-base font-bold text-slate-800" id="ai-top">-</p>
      <div class="bg-white rounded-lg p-3 mt-3 mb-3">
        <p class="text-xs font-bold text-slate-400 uppercase">Status Bisnis</p>
        <p class="text-xl font-black mt-0.5" id="ai-status">-</p>
      </div>
      <div id="ai-tips" class="space-y-1.5"></div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-4">
    <div class="card">
      <p class="text-xs font-bold text-slate-500 uppercase mb-3">Top 3 Produk</p>
      <div id="d-top3" class="space-y-2 text-sm"><span class="text-slate-400 text-xs">Belum ada data</span></div>
    </div>
    <div class="card">
      <p class="text-xs font-bold text-slate-500 uppercase mb-3">Performa Toko</p>
      <div id="d-toko-perf" class="space-y-2 text-sm"><span class="text-slate-400 text-xs">Belum ada data</span></div>
    </div>
    <div class="card">
      <p class="text-xs font-bold text-slate-500 uppercase mb-3">Order Status</p>
      <div class="space-y-2.5">
        <div class="flex justify-between text-sm"><span class="text-slate-500">📦 Siap Kirim</span><span class="font-bold text-yellow-500" id="st-siapkirim">0</span></div>
        <div class="flex justify-between text-sm"><span class="text-slate-500">🚚 Delivery</span><span class="font-bold text-blue-500" id="st-delivery">0</span></div>
        <div class="flex justify-between text-sm"><span class="text-slate-500">✅ Paid</span><span class="font-bold text-green-500" id="st-paid">0</span></div>
        <div class="flex justify-between text-sm"><span class="text-slate-500">❌ Batal</span><span class="font-bold text-red-400" id="st-batal">0</span></div>
      </div>
    </div>
    <div class="card">
      <p class="text-xs font-bold text-slate-500 uppercase mb-3">Ringkasan Hari Ini</p>
      <div class="space-y-2.5 text-sm">
        <div class="flex justify-between"><span class="text-slate-500">Omset</span><span class="font-bold" id="today-omset">Rp 0</span></div>
        <div class="flex justify-between"><span class="text-slate-500">Order</span><span class="font-bold" id="today-order">0</span></div>
        <div class="flex justify-between"><span class="text-slate-500">Profit</span><span class="font-bold text-green-600" id="today-profit">Rp 0</span></div>
        <div class="flex justify-between"><span class="text-slate-500">Pengeluaran</span><span class="font-bold text-red-500" id="today-biaya">Rp 0</span></div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════ ORDERS ═══ -->
<div id="orders" class="page space-y-4">
  <!-- Warning: no tokos configured -->
  <div id="noTokoWarn" class="hidden bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 flex items-center gap-3">
    <span class="text-xl">⚠️</span>
    <div>
      <p class="text-sm font-semibold text-amber-800">Belum ada toko/channel yang dikonfigurasi</p>
      <p class="text-xs text-amber-600">Tambahkan toko terlebih dahulu di menu <a href="#" onclick="go(event,'toko')" class="underline font-bold">Toko / Channel</a> sebelum input order.</p>
    </div>
  </div>
  <div class="flex items-center justify-between flex-wrap gap-2">
    <div class="flex gap-2 flex-wrap">
      <input id="srchOrder" type="text" placeholder="Cari produk, toko, resi..." class="inp" style="max-width:260px" oninput="renderOrders()"/>
      <select id="filterStatus" class="inp" style="max-width:150px" onchange="renderOrders()">
        <option value="">Semua Status</option>
        <option>Siap Kirim</option>
        <option>Delivery</option>
        <option>Paid</option>
        <option>Batal</option>
      </select>
    </div>
    <button class="btn" onclick="openModal('mOrder')">➕ Input Order</button>
  </div>
  <div class="card p-0 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b">
          <tr>
            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500">Tanggal</th>
            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500">Toko</th>
            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500">No Resi</th>
            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500">Produk</th>
            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500">Varian</th>
            <th class="text-right px-4 py-3 text-xs font-semibold text-slate-500">Qty</th>
            <th class="text-right px-4 py-3 text-xs font-semibold text-slate-500">Harga Jual</th>
            <th class="text-right px-4 py-3 text-xs font-semibold text-slate-500">Omset</th>
            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500">Status</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody id="orderTbody">
          <tr><td colspan="10" class="text-center py-10 text-slate-400">Belum ada order. Klik ➕ Input Order.</td></tr>
        </tbody>
      </table>
    </div>
    <div class="px-4 py-3 bg-slate-50 border-t flex justify-between">
      <p class="text-xs text-slate-500" id="orderCount">0 order</p>
      <p class="text-sm font-bold" id="orderGrandTotal">Total Omset: Rp 0</p>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════ CASHFLOW ═══ -->
<div id="cashflow" class="page space-y-4">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
    <div class="card border-l-4 border-green-500">
      <p class="text-xs text-slate-400 uppercase font-semibold">✅ Paid</p>
      <p class="text-2xl font-bold text-green-600 mt-1" id="cf-paid">Rp 0</p>
      <p class="text-xs text-slate-400 mt-1" id="cf-paid-count">0 order</p>
    </div>
    <div class="card border-l-4 border-blue-500">
      <p class="text-xs text-slate-400 uppercase font-semibold">🚚 Delivery</p>
      <p class="text-2xl font-bold text-blue-600 mt-1" id="cf-delivery">Rp 0</p>
      <p class="text-xs text-slate-400 mt-1" id="cf-delivery-count">0 order</p>
    </div>
    <div class="card border-l-4 border-yellow-500">
      <p class="text-xs text-slate-400 uppercase font-semibold">📦 Siap Kirim</p>
      <p class="text-2xl font-bold text-yellow-500 mt-1" id="cf-siapkirim">Rp 0</p>
      <p class="text-xs text-slate-400 mt-1" id="cf-siapkirim-count">0 order</p>
    </div>
    <div class="card border-l-4 border-slate-400">
      <p class="text-xs text-slate-400 uppercase font-semibold">💰 Total Omset (Paid)</p>
      <p class="text-2xl font-bold text-slate-800 mt-1" id="cf-omset">Rp 0</p>
      <p class="text-xs text-green-600 mt-1">Dari order Paid</p>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="card"><p class="text-xs text-slate-400 uppercase font-semibold">Uang Masuk (Paid)</p><p class="text-2xl font-bold text-green-600 mt-1" id="cf-masuk">Rp 0</p></div>
    <div class="card"><p class="text-xs text-slate-400 uppercase font-semibold">Uang Keluar</p><p class="text-2xl font-bold text-red-500 mt-1" id="cf-keluar">Rp 0</p></div>
    <div class="card"><p class="text-xs text-slate-400 uppercase font-semibold">Net Cashflow</p><p class="text-2xl font-bold text-blue-600 mt-1" id="cf-net">Rp 0</p></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="card">
      <p class="text-sm font-bold text-green-600 mb-3">✅ Order Paid</p>
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead class="bg-slate-50 border-b"><tr><th class="text-left px-2 py-2">Toko</th><th class="text-left px-2 py-2">Produk</th><th class="text-right px-2 py-2">Omset</th></tr></thead>
          <tbody id="cf-paid-list"></tbody>
        </table>
      </div>
    </div>
    <div class="card">
      <p class="text-sm font-bold text-blue-600 mb-3">🚚 Sedang Delivery</p>
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead class="bg-slate-50 border-b"><tr><th class="text-left px-2 py-2">Toko</th><th class="text-left px-2 py-2">Produk</th><th class="text-right px-2 py-2">Omset</th></tr></thead>
          <tbody id="cf-delivery-list"></tbody>
        </table>
      </div>
    </div>
    <div class="card">
      <p class="text-sm font-bold text-yellow-600 mb-3">📦 Siap Kirim</p>
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead class="bg-slate-50 border-b"><tr><th class="text-left px-2 py-2">Toko</th><th class="text-left px-2 py-2">Produk</th><th class="text-right px-2 py-2">Omset</th></tr></thead>
          <tbody id="cf-siapkirim-list"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Transaksi Manual - INLINE FORM (fixed: was openModal) -->
  <div class="card">
    <div class="flex items-center justify-between mb-3">
      <p class="text-sm font-bold text-slate-600">Transaksi Manual (Biaya / Pemasukan Lain)</p>
      <button class="btn btn-g btn-sm" onclick="toggleCFForm()">+ Tambah Transaksi</button>
    </div>

    <div id="cfFormBox" class="inline-form-box">
      <p class="text-sm font-bold text-slate-700 mb-1">Form Transaksi Manual</p>
      <p class="text-xs text-slate-400 mb-3">Tekan Enter untuk menyimpan</p>
      <form id="fCF" class="space-y-3" onsubmit="submitCF(event)">
        <div class="grid grid-cols-2 gap-3">
          <div><label class="lbl lbl-req">Tanggal</label><input name="tanggal" type="date" class="inp" required/></div>
          <div><label class="lbl">Tipe</label>
            <select name="tipe" class="inp">
              <option value="masuk">Uang Masuk</option>
              <option value="keluar">Uang Keluar</option>
            </select>
          </div>
        </div>
        <div><label class="lbl lbl-req">Keterangan</label><input name="ket" class="inp" placeholder="Keterangan transaksi" required/></div>
        <div><label class="lbl lbl-req">Jumlah (Rp)</label><input name="jumlah" type="number" class="inp" placeholder="0" min="0" required/></div>
        <div class="flex gap-2">
          <button type="submit" class="btn btn-g">💾 Simpan</button>
          <button type="button" class="btn btn-gray" onclick="toggleCFForm(false)">Batal</button>
        </div>
      </form>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b"><tr>
          <th class="text-left px-4 py-2 text-xs text-slate-500">Tanggal</th>
          <th class="text-left px-4 py-2 text-xs text-slate-500">Keterangan</th>
          <th class="text-left px-4 py-2 text-xs text-slate-500">Tipe</th>
          <th class="text-right px-4 py-2 text-xs text-slate-500">Jumlah</th>
          <th class="px-4 py-2"></th>
        </tr></thead>
        <tbody id="cfTbody"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════ INVENTORY ═══ -->
<div id="inventory" class="page space-y-4">
