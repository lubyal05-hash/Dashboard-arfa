<script>
// ═══════════════════════════════════════════════════════════════════════
// DB HELPERS
// ═══════════════════════════════════════════════════════════════════════
// Supabase client
const _SB = window.supabase.createClient(
  'https://vwzkshxkuzznqtmwsnky.supabase.co',
  'sb_publishable_wjyfBE4Rzs1Q9AlaYuS8ew_vHREqVaqI'
);

const DB = {
  // localStorage sebagai cache lokal
  get: k => JSON.parse(localStorage.getItem(k) || '[]'),
  set: (k, v) => localStorage.setItem(k, JSON.stringify(v)),
  getObj: k => JSON.parse(localStorage.getItem(k) || '{}'),
  setObj: (k, v) => localStorage.setItem(k, JSON.stringify(v)),

  // Load dari Supabase ke localStorage
  async load(table) {
    try {
      const { data, error } = await _SB.from(table).select('*').order('created_at', { ascending: false });
      if (data && !error) {
        localStorage.setItem(table, JSON.stringify(data));
        return data;
      }
    } catch(e) { console.log('Load error:', e); }
    return JSON.parse(localStorage.getItem(table) || '[]');
  },

  // Simpan ke Supabase
  async save(table, item) {
    try { await _SB.from(table).upsert(item); } catch(e) { console.log('Save error:', e); }
  },

  // Hapus dari Supabase
  async remove(table, id) {
    try { await _SB.from(table).delete().eq('id', id); } catch(e) { console.log('Remove error:', e); }
  }
};

const fmt = n => 'Rp ' + Number(n || 0).toLocaleString('id-ID');
const uid = () => Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
const today = () => new Date().toISOString().slice(0, 10);

const TITLES = {
