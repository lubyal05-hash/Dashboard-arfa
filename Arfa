}

// ═══════════════════════════════════════════════════════════════════════
// AI INSIGHT
// ═══════════════════════════════════════════════════════════════════════
function renderAI() {
  const orders = DB.get('orders').filter(o => o.status !== 'Batal');
  const biaya = DB.get('biaya');
  const totalOmset = orders.reduce((s, o) => s + (o.omset || 0), 0);
  const totalBiaya = biaya.reduce((s, b) => s + b.jumlah, 0);

  const pm = {};
  orders.forEach(o => { pm[o.product] = (pm[o.product] || 0) + (o.qty || 1); });
  const top5 = Object.entries(pm).sort((a, b) => b[1] - a[1]).slice(0, 5);

  const tm = {};
  orders.forEach(o => { const t = o.toko || 'Langsung'; tm[t] = (tm[t] || 0) + (o.omset || 0); });
  const topCh = Object.entries(tm).sort((a, b) => b[1] - a[1]);

  document.getElementById('ai-performa').innerHTML = orders.length === 0
    ? '<span class="text-slate-400 text-xs">Belum ada data order</span>'
    : `
    <div class="flex justify-between"><span class="text-slate-500">Total Omset</span><span class="font-bold">${fmt(totalOmset)}</span></div>
    <div class="flex justify-between"><span class="text-slate-500">Est. Profit (20%)</span><span class="font-bold text-green-600">${fmt(totalOmset * 0.2)}</span></div>
    <div class="flex justify-between"><span class="text-slate-500">Total Order</span><span class="font-bold">${orders.length}</span></div>
    <div class="flex justify-between"><span class="text-slate-500">Total Biaya</span><span class="font-bold text-red-500">${fmt(totalBiaya)}</span></div>
    <div class="flex justify-between"><span class="text-slate-500">Avg Order Value</span><span class="font-bold">${orders.length ? fmt(Math.round(totalOmset / orders.length)) : '-'}</span></div>`;

  const reks = [];
  if (totalBiaya > totalOmset * 0.5) reks.push({ i: '⚠️', t: 'Biaya operasional terlalu tinggi (>50% omset). Evaluasi pengeluaran.', c: 'bg-red-50' });
  if (orders.length < 10) reks.push({ i: '📢', t: 'Order masih sedikit. Tingkatkan promosi di channel terbaik.', c: 'bg-orange-50' });
  if (top5.length > 0) reks.push({ i: '🏆', t: `Fokus stok produk "${top5[0][0]}" — paling banyak terjual.`, c: 'bg-green-50' });
  if (topCh.length > 0) reks.push({ i: '🚀', t: `Channel "${topCh[0][0]}" paling menghasilkan. Tingkatkan di sana.`, c: 'bg-blue-50' });
  if (!reks.length) reks.push({ i: '✅', t: 'Bisnis berjalan baik! Terus pantau data secara rutin.', c: 'bg-green-50' });

  document.getElementById('ai-rek').innerHTML = reks.map(r =>
    `<div class="flex items-start gap-2 p-2 ${r.c} rounded-lg"><span>${r.i}</span><p class="text-xs text-slate-700">${r.t}</p></div>`).join('');

  document.getElementById('ai-prod').innerHTML = top5.length
    ? top5.map((p, i) => `<div class="flex justify-between"><span>${i + 1}. ${p[0]}</span><span class="font-bold text-blue-600">${p[1]} unit</span></div>`).join('')
    : '<span class="text-slate-400 text-xs">Belum ada data</span>';

  document.getElementById('ai-chan').innerHTML = topCh.length
    ? topCh.map((c, i) => `<div class="flex justify-between"><span>${i + 1}. ${c[0]}</span><span class="font-bold text-green-600">${fmt(c[1])}</span></div>`).join('')
    : '<span class="text-slate-400 text-xs">Belum ada data</span>';
}
</script>

<script>
// ═══════════════════════════════════════════════════════════════════════
// LAPORAN
// ═══════════════════════════════════════════════════════════════════════
let lapChartInst = null;

function renderLaporan() {
  const orders = DB.get('orders').filter(o => o.status !== 'Batal');
  const bu = document.getElementById('lapBu')?.value || '';
  const ch = document.getElementById('lapCh')?.value || '';

  const months = [...new Set(orders.map(o => (o.tanggal || o.created_at || '').slice(0, 7)))].filter(Boolean).sort().reverse();
  const tokos  = [...new Set(orders.map(o => o.toko || 'Langsung'))].sort();

  const selBu = document.getElementById('lapBu');
  const selCh = document.getElementById('lapCh');
  selBu.innerHTML = '<option value="">Semua Bulan</option>' + months.map(m => `<option value="${m}" ${bu===m?'selected':''}>${m}</option>`).join('');
  selCh.innerHTML = '<option value="">Semua Toko</option>' + tokos.map(t => `<option value="${t}" ${ch===t?'selected':''}>${t}</option>`).join('');

  const filtered = orders.filter(o =>
    (!bu || (o.tanggal || o.created_at || '').startsWith(bu)) &&
    (!ch || (o.toko || 'Langsung') === ch)
  );

  const totalOmset = filtered.reduce((s, o) => s + (o.omset || 0), 0);
  document.getElementById('lapStats').innerHTML = `
    <div class="card"><p class="text-xs text-slate-400 uppercase font-semibold">Total Omset</p><p class="text-xl font-bold text-slate-800 mt-1">${fmt(totalOmset)}</p></div>
    <div class="card"><p class="text-xs text-slate-400 uppercase font-semibold">Est. Profit</p><p class="text-xl font-bold text-green-600 mt-1">${fmt(totalOmset * 0.2)}</p></div>
    <div class="card"><p class="text-xs text-slate-400 uppercase font-semibold">Total Order</p><p class="text-xl font-bold text-slate-800 mt-1">${filtered.length}</p></div>
    <div class="card"><p class="text-xs text-slate-400 uppercase font-semibold">Avg Order</p><p class="text-xl font-bold text-slate-800 mt-1">${filtered.length ? fmt(Math.round(totalOmset / filtered.length)) : '-'}</p></div>`;

  const byMonth = {};
  filtered.forEach(o => { const m = (o.tanggal || o.created_at || '').slice(0, 7); if (m) byMonth[m] = (byMonth[m] || 0) + (o.omset || 0); });
  const labels = Object.keys(byMonth).sort();

  const ctx = document.getElementById('lapChart').getContext('2d');
  if (lapChartInst) lapChartInst.destroy();
  lapChartInst = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [
        { label: 'Omset', data: labels.map(m => byMonth[m]), backgroundColor: 'rgba(59,130,246,.7)', borderRadius: 4 },
        { label: 'Est. Profit', data: labels.map(m => byMonth[m] * 0.2), backgroundColor: 'rgba(34,197,94,.7)', borderRadius: 4 }
      ]
    },
    options: {
      plugins: { legend: { position: 'top' } },
      scales: {
        y: { ticks: { callback: v => fmt(v) }, grid: { color: '#f1f5f9' } },
        x: { grid: { display: false } }
      }
    }
  });

  const statusBadge = s => {
    const map = { 'Siap Kirim': 'bg-yellow-100 text-yellow-700', 'Delivery': 'bg-blue-100 text-blue-700', 'Paid': 'bg-green-100 text-green-700', 'Batal': 'bg-red-100 text-red-700' };
    return `<span class="text-xs px-2 py-0.5 rounded-full font-semibold ${map[s] || 'bg-slate-100 text-slate-700'}">${s}</span>`;
  };

  document.getElementById('lapTbody').innerHTML = filtered.length
    ? filtered.map(o => `
        <tr class="border-t hover:bg-slate-50">
          <td class="px-4 py-3 text-xs text-slate-500">${o.tanggal || o.created_at?.slice(0,10) || '-'}</td>
          <td class="px-4 py-3 text-sm">${o.toko || '-'}</td>
          <td class="px-4 py-3">${o.product}</td>
          <td class="px-4 py-3 text-xs text-slate-500">${o.varian || '-'}</td>
          <td class="px-4 py-3 text-right">${o.qty}</td>
          <td class="px-4 py-3 text-right font-bold">${fmt(o.omset || 0)}</td>
          <td class="px-4 py-3">${statusBadge(o.status)}</td>
        </tr>`).join('')
    : `<tr><td colspan="7"><div class="empty-state"><div class="icon">📄</div><p>Tidak ada data untuk filter ini.</p></div></td></tr>`;
}

function exportCSV() {
  const orders = DB.get('orders');
  if (orders.length === 0) { toast('Tidak ada data untuk diekspor', 'error'); return; }
  const rows = [['Tanggal','Toko','No Resi','Produk','Varian','Qty','Harga Jual','Omset','Fee MP','Biaya Program','Premi','Pre Order','Voucher','Gratis Ongkir','Promo Xtra','Biaya Pemasaran','Biaya Affiliate','Status']];
  orders.forEach(o => rows.push([
    o.tanggal || o.created_at?.slice(0,10) || '',
    o.toko || '', o.no_resi || '', o.product, o.varian || '',
    o.qty, o.harga_jual, o.omset || 0,
    o.fee_mp || 0, o.biaya_program || 0, o.premi || 0, o.pre_order || 0,
    o.voucher || 0, o.gratis_ongkir || 0, o.promo_xtra || 0,
    o.biaya_pemasaran || 0, o.biaya_affiliate || 0, o.status
  ]));
  const csv = rows.map(r => r.map(v => `"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,\uFEFF' + encodeURIComponent(csv);
  a.download = 'orders_' + today() + '.csv';
  a.click();
  toast('CSV berhasil diekspor!');
}
</script>

<script>
// ═══════════════════════════════════════════════════════════════════════
// SETTINGS
// ═══════════════════════════════════════════════════════════════════════
function loadSettings() {
  const s = DB.getObj('settings');
  document.getElementById('set-nama').value   = s.nama   || '';
  document.getElementById('set-owner').value  = s.owner  || '';
  document.getElementById('set-telp').value   = s.telp   || '';
  document.getElementById('set-alamat').value = s.alamat || '';
  document.getElementById('set-gsurl').value  = s.gsUrl  || '';
  document.getElementById('set-gssync').checked = s.gsSync || false;
}

function saveSettings() {
  const existing = DB.getObj('settings');
  const s = {
    nama:   document.getElementById('set-nama').value.trim(),
    owner:  document.getElementById('set-owner').value.trim(),
    telp:   document.getElementById('set-telp').value.trim(),
    alamat: document.getElementById('set-alamat').value.trim(),
    gsUrl:  existing.gsUrl  || '',
    gsSync: existing.gsSync || false
  };
  DB.setObj('settings', s);
  applySettings();
  toast('✅ Pengaturan disimpan!');
}

function saveGS() {
  const s = DB.getObj('settings');
  s.gsUrl  = document.getElementById('set-gsurl').value.trim();
  s.gsSync = document.getElementById('set-gssync').checked;
  DB.setObj('settings', s);
  toast('✅ Koneksi Google Sheets disimpan!');
}

async function testGS() {
  const url = document.getElementById('set-gsurl').value.trim();
  const el  = document.getElementById('gs-status');
  if (!url) { el.textContent = '⚠️ URL belum diisi'; return; }
  el.textContent = '⏳ Menguji...';
  try {
    const r = await fetch(url + '?action=test');
    const d = await r.json();
    el.textContent = d.status === 'ok' ? '✅ Terhubung!' : '❌ Gagal: ' + d.message;
  } catch (err) {
    el.textContent = '❌ Tidak dapat terhubung';
  }
}

async function syncGS(order) {
  const s = DB.getObj('settings');
  if (!s.gsUrl || !s.gsSync) return;
  try {
    await fetch(s.gsUrl, { method: 'POST', body: JSON.stringify({ action: 'addOrder', ...order }) });
  } catch (e) { console.log('GS sync failed:', e); }
}

// ═══════════════════════════════════════════════════════════════════════
// DATA MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════
function exportAll() {
  const data = {
    orders:    DB.get('orders'),
    inventory: DB.get('inventory'),
    cashflow:  DB.get('cashflow'),
    biaya:     DB.get('biaya'),
    tokos:     DB.get('tokos'),
    settings:  DB.getObj('settings')
  };
  const a = document.createElement('a');
  a.href = 'data:application/json;charset=utf-8,' + encodeURIComponent(JSON.stringify(data, null, 2));
  a.download = 'backup_' + today() + '.json';
  a.click();
  toast('✅ Data berhasil diekspor!');
}

function importAll() {
  document.getElementById('importFile').click();
}

function doImport(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    try {
      const data = JSON.parse(ev.target.result);
      if (data.orders)    DB.set('orders', data.orders);
      if (data.inventory) DB.set('inventory', data.inventory);
      if (data.cashflow)  DB.set('cashflow', data.cashflow);
      if (data.biaya)     DB.set('biaya', data.biaya);
      if (data.tokos)     DB.set('tokos', data.tokos);
      if (data.settings)  DB.setObj('settings', data.settings);
      applySettings();
      renderDashboard();
      updateNavBadges();
      toast('✅ Data berhasil diimport!');
      e.target.value = '';
    } catch (err) { toast('File tidak valid! Pastikan format JSON benar.', 'error'); }
  };
  reader.readAsText(file);
}

function clearAll() {
  if (!confirm('⚠️ Hapus SEMUA data? Tindakan ini tidak bisa dibatalkan!')) return;
  if (!confirm('Yakin? Semua order, inventory, cashflow, biaya, dan toko akan terhapus permanen!')) return;
  ['orders', 'inventory', 'cashflow', 'biaya', 'tokos'].forEach(k => localStorage.removeItem(k));
  renderDashboard();
  updateNavBadges();
  toast('Semua data berhasil dihapus.');
}

// ═══════════════════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════════════════
// Load semua data dari Supabase saat pertama buka
async function initApp() {
  const loadingEl = document.createElement('div');
  loadingEl.id = 'appLoading';
  loadingEl.style.cssText = 'position:fixed;inset:0;background:rgba(15,23,42,.8);z-index:9999;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;color:#fff';
  loadingEl.innerHTML = '<div style="width:40px;height:40px;border:3px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite"></div><p style="font-size:14px;font-weight:600">Memuat data...</p>';
  document.body.appendChild(loadingEl);

  await Promise.all([
    DB.load('orders'),
    DB.load('inventory'),
    DB.load('cashflow'),
    DB.load('biaya'),
    DB.load('tokos')
  ]);

  loadingEl.remove();
  renderDashboard();
  updateNavBadges();
}
initApp();
</script>
</body>
