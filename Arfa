<script>
// ═══════════════════════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════════════════════
let dashChartInst = null;

function renderDashboard() {
  const orders = DB.get('orders');
  const activeOrders = orders.filter(o => o.status !== 'Batal');
  const biaya = DB.get('biaya');
  const todayStr = today();

  // Quick start guide
  const qs = document.getElementById('quickStart');
  if (qs) qs.style.display = orders.length === 0 ? 'block' : 'none';

  const totalOmset = activeOrders.reduce((s, o) => s + (o.omset || 0), 0);
  const totalBiaya = biaya.reduce((s, b) => s + b.jumlah, 0);
  const saldo = totalOmset - totalBiaya;

  document.getElementById('d-omset').textContent = fmt(totalOmset);
  document.getElementById('d-profit').textContent = fmt(totalOmset * 0.2);
  document.getElementById('d-pengeluaran').textContent = fmt(totalBiaya);
  document.getElementById('d-saldo').textContent = fmt(saldo);

  // Today
  const todayOrders = activeOrders.filter(o => (o.tanggal || o.created_at || '').startsWith(todayStr));
  const todayBiaya = biaya.filter(b => b.tanggal === todayStr).reduce((s, b) => s + b.jumlah, 0);
  document.getElementById('today-omset').textContent = fmt(todayOrders.reduce((s, o) => s + (o.omset || 0), 0));
  document.getElementById('today-order').textContent = todayOrders.length;
  document.getElementById('today-profit').textContent = fmt(todayOrders.reduce((s, o) => s + (o.omset || 0), 0) * 0.2);
  document.getElementById('today-biaya').textContent = fmt(todayBiaya);

  // Status counts
  document.getElementById('st-siapkirim').textContent = orders.filter(o => o.status === 'Siap Kirim').length;
  document.getElementById('st-delivery').textContent = orders.filter(o => o.status === 'Delivery').length;
  document.getElementById('st-paid').textContent = orders.filter(o => o.status === 'Paid').length;
  document.getElementById('st-batal').textContent = orders.filter(o => o.status === 'Batal').length;

  // Top 3 products
  const pm = {};
  activeOrders.forEach(o => { pm[o.product] = (pm[o.product] || 0) + (o.qty || 1); });
  const top3 = Object.entries(pm).sort((a, b) => b[1] - a[1]).slice(0, 3);
  document.getElementById('d-top3').innerHTML = top3.length
    ? top3.map((p, i) => `<div class="flex justify-between"><span>${['🥇','🥈','🥉'][i]} ${p[0]}</span><span class="font-bold text-blue-600">${p[1]} unit</span></div>`).join('')
    : '<span class="text-slate-400 text-xs">Belum ada data</span>';

  // Toko performance
  const tm = {};
  activeOrders.forEach(o => { const t = o.toko || 'Langsung'; tm[t] = (tm[t] || 0) + (o.omset || 0); });
  const topT = Object.entries(tm).sort((a, b) => b[1] - a[1]).slice(0, 4);
  document.getElementById('d-toko-perf').innerHTML = topT.length
    ? topT.map(t => `<div class="flex justify-between"><span class="truncate">${t[0]}</span><span class="font-bold ml-2">${fmt(t[1])}</span></div>`).join('')
    : '<span class="text-slate-400 text-xs">Belum ada data</span>';

  // AI panel
  const aiTop = top3[0]?.[0] || '-';
  document.getElementById('ai-top').textContent = aiTop + (top3[0] ? ` (${top3[0][1]} unit)` : '');
  document.getElementById('ai-update').textContent = new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
  const se = document.getElementById('ai-status');
  if (orders.length === 0) { se.textContent = 'MULAI INPUT'; se.className = 'text-xl font-black text-blue-600'; }
  else if (totalBiaya > totalOmset * 0.5) { se.textContent = 'PERLU EVALUASI'; se.className = 'text-xl font-black text-red-600'; }
  else if (orders.length >= 20) { se.textContent = 'BAGUS! 🔥'; se.className = 'text-xl font-black text-green-600'; }
  else { se.textContent = 'BERKEMBANG'; se.className = 'text-xl font-black text-orange-500'; }
  const tips = [];
  if (top3[0]) tips.push(`⚡ Pastikan stok <b>${top3[0][0]}</b> selalu tersedia`);
  if (totalBiaya > totalOmset * 0.3) tips.push('⚠️ Biaya operasional cukup tinggi, evaluasi pengeluaran');
  if (orders.length > 0 && todayOrders.length === 0) tips.push('📢 Belum ada order hari ini');
  document.getElementById('ai-tips').innerHTML = tips.map(t => `<p class="text-xs text-slate-600">${t}</p>`).join('');

  // 14-day chart
  const byDay = {};
  activeOrders.forEach(o => {
    const d = (o.tanggal || o.created_at || '').slice(0, 10);
    if (d) byDay[d] = (byDay[d] || 0) + (o.omset || 0);
  });
  const days14 = [];
  for (let i = 13; i >= 0; i--) {
    const dt = new Date(); dt.setDate(dt.getDate() - i);
    days14.push(dt.toISOString().slice(0, 10));
  }
  const ctx = document.getElementById('dashChart')?.getContext('2d');
  if (ctx) {
    if (dashChartInst) dashChartInst.destroy();
    dashChartInst = new Chart(ctx, {
      type: 'line',
      data: {
        labels: days14.map(d => d.slice(5)),
        datasets: [{
          label: 'Omset',
          data: days14.map(d => byDay[d] || 0),
          borderColor: '#22c55e',
          backgroundColor: 'rgba(34,197,94,.1)',
          tension: 0.4, fill: true, pointRadius: 3
        }]
      },
      options: {
        plugins: { legend: { display: false } },
        scales: {
          y: { ticks: { callback: v => fmt(v) }, grid: { color: '#f1f5f9' } },
          x: { grid: { display: false } }
        }
      }
    });
  }

  updateNavBadges();
}
</script>

<script>
// ═══════════════════════════════════════════════════════════════════════
// ORDERS
// ═══════════════════════════════════════════════════════════════════════
function updateTokoSelect() {
  const tokos = DB.get('tokos');
  const sel = document.getElementById('tokoSelect');
  sel.innerHTML = '<option value="">-- Pilih Toko --</option>' +
    tokos.map(t => `<option value="${t.nama}">${t.nama} (${t.platform})</option>`).join('');
}

function updateProdukSuggest() {
  const inv = DB.get('inventory');
  document.getElementById('produkSuggest').innerHTML = inv.map(p => `<option value="${p.nama}">`).join('');
}

function calcOrder() {
  const f = document.getElementById('fOrder');
  if (!f) return;
  const qty = +f.qty?.value || 0;
  const harga = +f.harga_jual?.value || 0;
  const omset = qty * harga;
  const totalBiayaMP =
    (+f.fee_mp?.value || 0) + (+f.biaya_program?.value || 0) + (+f.premi?.value || 0) +
    (+f.pre_order?.value || 0) + (+f.voucher?.value || 0) + (+f.gratis_ongkir?.value || 0) +
    (+f.promo_xtra?.value || 0) + (+f.biaya_pemasaran?.value || 0) + (+f.biaya_affiliate?.value || 0);
  document.getElementById('oOmset').textContent = fmt(omset);
  document.getElementById('oBiayaMP').textContent = fmt(totalBiayaMP);
}

function showONotif(msg, type) {
  toast(msg, type === 's' ? 'success' : 'error');
  const n = document.getElementById('oNotif');
  if (!n) return;
  n.className = 'mt-2 p-3 rounded-lg text-sm font-medium ' +
    (type === 's' ? 'bg-green-50 text-green-800' : 'bg-red-50 text-red-800');
  n.textContent = msg;
  n.classList.remove('hidden');
  if (type === 's') setTimeout(() => { n.classList.add('hidden'); closeModal('mOrder'); }, 2000);
}

function submitOrder(e) {
  e.preventDefault();
  const fd = new FormData(e.target);
  const qty = +fd.get('qty');
  const harga = +fd.get('harga_jual');
  const omset = qty * harga;

  if (!fd.get('toko')) return showONotif('Nama toko wajib dipilih', 'e');
  if (!fd.get('product').trim()) return showONotif('Nama produk wajib diisi', 'e');
  if (harga <= 0) return showONotif('Harga jual harus lebih dari 0', 'e');

  const totalBiayaMP =
    (+fd.get('fee_mp') || 0) + (+fd.get('biaya_program') || 0) + (+fd.get('premi') || 0) +
    (+fd.get('pre_order') || 0) + (+fd.get('voucher') || 0) + (+fd.get('gratis_ongkir') || 0) +
    (+fd.get('promo_xtra') || 0) + (+fd.get('biaya_pemasaran') || 0) + (+fd.get('biaya_affiliate') || 0);

  const order = {
    id: uid(),
    created_at: new Date().toISOString(),
    tanggal: fd.get('tanggal') || today(),
    toko: fd.get('toko'),
    no_resi: fd.get('no_resi').trim(),
    product: fd.get('product').trim(),
    varian: fd.get('varian').trim(),
    qty: qty,
    harga_jual: harga,
    omset: omset,
    fee_mp: +fd.get('fee_mp') || 0,
    biaya_program: +fd.get('biaya_program') || 0,
    premi: +fd.get('premi') || 0,
    pre_order: +fd.get('pre_order') || 0,
    voucher: +fd.get('voucher') || 0,
    gratis_ongkir: +fd.get('gratis_ongkir') || 0,
    promo_xtra: +fd.get('promo_xtra') || 0,
    biaya_pemasaran: +fd.get('biaya_pemasaran') || 0,
    biaya_affiliate: +fd.get('biaya_affiliate') || 0,
    total_biaya_mp: totalBiayaMP,
    total: omset,
    status: fd.get('status') || 'Siap Kirim'
  };

  const orders = DB.get('orders');
  orders.unshift(order);
  DB.set('orders', orders);
  DB.save('orders', order); // sync ke Supabase

  // Proper form reset
  e.target.reset();
  e.target.qty.value = 1;
  document.getElementById('oOmset').textContent = 'Rp 0';
  document.getElementById('oBiayaMP').textContent = 'Rp 0';

  showONotif('✅ Order disimpan! ID: ' + order.id.slice(-6).toUpperCase(), 's');
  renderOrders();
  renderDashboard();

  const s = DB.getObj('settings');
  if (s.gsUrl && s.gsSync) syncGS(order);
}

function renderOrders() {
  const orders = DB.get('orders');
  const tokos = DB.get('tokos');
  const q = (document.getElementById('srchOrder')?.value || '').toLowerCase();
  const fs = document.getElementById('filterStatus')?.value || '';

  // Show/hide no-toko warning
  const warn = document.getElementById('noTokoWarn');
  if (warn) warn.classList.toggle('hidden', tokos.length > 0);

  const filtered = orders.filter(o =>
    (!q || (o.product || '').toLowerCase().includes(q) ||
           (o.toko || '').toLowerCase().includes(q) ||
           (o.no_resi || '').toLowerCase().includes(q)) &&
    (!fs || o.status === fs)
  );

  const statusBadge = s => {
    const map = {
      'Siap Kirim': 'bg-yellow-100 text-yellow-700',
      'Delivery':   'bg-blue-100 text-blue-700',
      'Paid':       'bg-green-100 text-green-700',
      'Batal':      'bg-red-100 text-red-700'
    };
    return `<span class="text-xs px-2 py-0.5 rounded-full font-semibold ${map[s] || 'bg-slate-100 text-slate-700'}">${s}</span>`;
  };

  const tbody = document.getElementById('orderTbody');
  if (filtered.length === 0) {
    tbody.innerHTML = orders.length === 0
      ? `<tr><td colspan="10"><div class="empty-state"><div class="icon">🛒</div><p>Belum ada order.</p><p class="hint">Klik <strong>➕ Input Order</strong> untuk mulai mencatat penjualan.</p></div></td></tr>`
      : `<tr><td colspan="10" class="text-center py-10 text-slate-400">Tidak ada order yang cocok dengan filter.</td></tr>`;
  } else {
    tbody.innerHTML = filtered.map(o => `
      <tr class="border-t hover:bg-slate-50">
        <td class="px-4 py-3 text-xs text-slate-500">${o.tanggal || o.created_at?.slice(0,10) || '-'}</td>
        <td class="px-4 py-3 font-medium text-sm">${o.toko || '-'}</td>
        <td class="px-4 py-3 text-xs text-slate-500">${o.no_resi || '-'}</td>
        <td class="px-4 py-3">${o.product}</td>
        <td class="px-4 py-3 text-xs text-slate-500">${o.varian || '-'}</td>
        <td class="px-4 py-3 text-right">${o.qty}</td>
        <td class="px-4 py-3 text-right">${fmt(o.harga_jual)}</td>
        <td class="px-4 py-3 text-right font-bold">${fmt(o.omset)}</td>
        <td class="px-4 py-3">
          <select class="text-xs border rounded px-1 py-0.5 bg-white" onchange="updateOrderStatus('${o.id}',this.value)">
            ${['Siap Kirim','Delivery','Paid','Batal'].map(s => `<option ${o.status===s?'selected':''}>${s}</option>`).join('')}
          </select>
        </td>
        <td class="px-4 py-3">
          <button onclick="delOrder('${o.id}')" class="text-red-400 hover:text-red-600 text-sm" title="Hapus order">🗑</button>
        </td>
      </tr>`).join('');
  }

  document.getElementById('orderCount').textContent = filtered.length + ' order';
  document.getElementById('orderGrandTotal').textContent = 'Total Omset: ' + fmt(filtered.reduce((s, o) => s + (o.omset || 0), 0));
  updateNavBadges();
}

function updateOrderStatus(id, status) {
  const orders = DB.get('orders');
  const o = orders.find(x => x.id === id);
  if (o) {
    o.status = status;
    DB.set('orders', orders);
    renderDashboard();
    toast('Status order diperbarui: ' + status);
  }
}

function delOrder(id) {
  if (!confirm('Hapus order ini? Tindakan tidak bisa dibatalkan.')) return;
  DB.set('orders', DB.get('orders').filter(o => o.id !== id));
  DB.remove('orders', id);
  renderOrders();
  renderDashboard();
  toast('Order berhasil dihapus.');
}
</script>

<script>
// ═══════════════════════════════════════════════════════════════════════
// CASHFLOW
// ═══════════════════════════════════════════════════════════════════════
// FIX: Use FormData consistently (form uses name attributes)
function submitCF(e) {
  e.preventDefault();
  const fd = new FormData(e.target);
  const tanggal = fd.get('tanggal');
  const ket = fd.get('ket');
  const tipe = fd.get('tipe');
  const jumlah = +fd.get('jumlah');

  if (!tanggal) return toast('Tanggal wajib diisi', 'error');
  if (!ket || !ket.trim()) return toast('Keterangan wajib diisi', 'error');
  if (!jumlah || jumlah <= 0) return toast('Jumlah harus lebih dari 0', 'error');

  const cf = DB.get('cashflow');
  cf.unshift({ id: uid(), tanggal, ket: ket.trim(), tipe, jumlah });
  DB.set('cashflow', cf);
  DB.save('cashflow', cf[0]);
  toggleCFForm(false);
  renderCashflow();
  toast('✅ Transaksi berhasil disimpan!');
}

function renderCashflow() {
  const orders = DB.get('orders');
  const cf = DB.get('cashflow');
  const biaya = DB.get('biaya');

